PORT=8765

#Para lanzar el server.js por terminal y el servicio del compose db exclusivamente mediante:
#docker compose up db
#DB_HOST=localhost

#Para enlazar por nombre de servicio del compose en este caso el servicio de base de datos es: db
#a utilizar cuando levantes toda la aplicacion desde: 
#docker compose up -d
DB_HOST=db

DB_USERNAME=root
DB_PASSWORD=example
DB_NAME=fake_store
DB_PORT=27017
DATABASE_URL=mongodb://$DB_USERNAME:$DB_PASSWORD@$DB_HOST:$DB_PORT/$DB_NAME?authSource=admin